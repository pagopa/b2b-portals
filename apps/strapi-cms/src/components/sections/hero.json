{
  "collectionName": "components_sections_heroes",
  "info": {
    "displayName": "Hero",
    "description": ""
  },
  "options": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "subtitle": {
      "type": "richtext"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "background": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images"
      ]
    },
    "theme": {
      "type": "enumeration",
      "required": true,
      "default": "light",
      "enum": [
        "light",
        "dark"
      ]
    },
    "inverse": {
      "type": "boolean",
      "required": false,
      "default": false
    },
    "size": {
      "type": "enumeration",
      "required": true,
      "default": "small",
      "enum": [
        "small",
        "medium",
        "big"
      ]
    },
    "sectionID": {
      "type": "string",
      "unique": false,
      "regex": "^[a-z]+[a-z\\-]*$"
    },
    "ctaButtons": {
      "type": "component",
      "component": "components.cta-button-simple",
      "repeatable": true,
      "max": 2
    },
    "storeButtons": {
      "type": "component",
      "component": "components.store-buttons",
      "repeatable": false
    },
    "link": {
      "type": "component",
      "component": "components.link",
      "repeatable": false
    },
    "titleTag": {
      "type": "enumeration",
      "required": false,
      "default": "p",
      "enum": [
        "h1",
        "h2",
        "h3",
        "h4",
        "h5",
        "h6",
        "p"
      ]
    },
    "customBgColor": {
      "type": "customField",
      "customField": "plugin::color-picker.color",
      "regex": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$"
    }
  }
}
