{
  "collectionName": "components_sections_cards",
  "info": {
    "displayName": "Cards",
    "description": ""
  },
  "options": {},
  "attributes": {
    "theme": {
      "type": "enumeration",
      "required": true,
      "default": "light",
      "enum": [
        "light",
        "dark"
      ]
    },
    "title": {
      "type": "string",
      "required": true
    },
    "subtitle": {
      "type": "string"
    },
    "items": {
      "type": "component",
      "component": "components.cards-item",
      "repeatable": true,
      "required": true,
      "min": 1
    },
    "sectionID": {
      "type": "string",
      "regex": "^[a-z]+[a-z\\-]*$"
    },
    "body": {
      "type": "richtext"
    },
    "ctaButtons": {
      "type": "component",
      "component": "components.cta-button-simple",
      "repeatable": true,
      "max": 2
    },
    "textPosition": {
      "type": "enumeration",
      "required": true,
      "default": "left",
      "enum": [
        "left",
        "center",
        "right",
        "none"
      ]
    },
    "cardsAlignment": {
      "type": "enumeration",
      "default": "left",
      "enum": [
        "left",
        "center"
      ]
    },
    "bottomCTA": {
      "type": "component",
      "component": "components.cta-button-simple",
      "repeatable": false
    },
    "titleTag": {
      "type": "enumeration",
      "default": "h2",
      "enum": [
        "h1",
        "h2"
      ]
    },
    "customBgColor": {
      "type": "customField",
      "customField": "plugin::color-picker.color",
      "regex": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$"
    }
  }
}
