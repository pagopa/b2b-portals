{
  "collectionName": "components_sections_accordions",
  "info": {
    "displayName": "Accordion",
    "description": ""
  },
  "options": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "subtitle": {
      "type": "string",
      "required": false
    },
    "description": {
      "type": "richtext"
    },
    "theme": {
      "type": "enumeration",
      "required": true,
      "default": "light",
      "enum": [
        "light",
        "dark"
      ]
    },
    "layout": {
      "type": "enumeration",
      "required": true,
      "default": "center",
      "enum": [
        "left",
        "center"
      ]
    },
    "accordionItems": {
      "type": "component",
      "component": "components.accordion-item",
      "repeatable": true,
      "required": true,
      "min": 1
    },
    "sectionID": {
      "type": "string",
      "unique": false,
      "regex": "^[a-z]+[a-z\\-]*$"
    },
    "textAlignment": {
      "type": "enumeration",
      "required": true,
      "default": "center",
      "enum": [
        "left",
        "center",
        "right"
      ]
    },
    "trackItemOpen": {
      "type": "boolean",
      "default": false
    },
    "customBgColor": {
      "type": "customField",
      "customField": "plugin::color-picker.color",
      "regex": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$"
    }
  }
}
