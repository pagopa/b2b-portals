{
  "collectionName": "components_sections_editorials",
  "info": {
    "displayName": "Editorial",
    "description": ""
  },
  "options": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "eyelet": {
      "type": "string"
    },
    "body": {
      "type": "richtext",
      "required": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "theme": {
      "type": "enumeration",
      "required": true,
      "default": "light",
      "enum": [
        "light",
        "dark"
      ]
    },
    "pattern": {
      "type": "enumeration",
      "required": true,
      "default": "none",
      "enum": [
        "none",
        "dots",
        "solid"
      ]
    },
    "width": {
      "type": "enumeration",
      "required": true,
      "default": "standard",
      "enum": [
        "standard",
        "wide",
        "center"
      ]
    },
    "reversed": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "sectionID": {
      "type": "string",
      "required": false,
      "unique": false,
      "regex": "^[a-z]+[a-z\\-]*$"
    },
    "ctaButtons": {
      "type": "component",
      "component": "components.cta-button-simple",
      "repeatable": true,
      "max": 2
    },
    "storeButtons": {
      "type": "component",
      "component": "components.store-buttons",
      "repeatable": false
    },
    "mobileImage": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "titleTag": {
      "type": "enumeration",
      "default": "h2",
      "enum": [
        "h1",
        "h2",
        "h3",
        "h4",
        "h5",
        "h6",
        "p"
      ]
    },
    "ariaLabelSection": {
      "type": "string"
    }
  }
}
