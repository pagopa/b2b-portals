{
  "collectionName": "components_sections_press_releases",
  "info": {
    "displayName": "PressRelease",
    "description": ""
  },
  "options": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "subtitle": {
      "type": "text"
    },
    "body": {
      "type": "richtext",
      "required": false
    },
    "sectionID": {
      "type": "string",
      "regex": "^[a-z]+[a-z\\-]*$"
    },
    "date": {
      "type": "date",
      "required": true
    },
    "backlink": {
      "type": "component",
      "component": "components.link",
      "repeatable": false
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "metadata": {
      "type": "component",
      "component": "press-release.press-release-meta",
      "repeatable": false
    },
    "paragraphs": {
      "type": "component",
      "component": "press-release.press-release-paragraph",
      "repeatable": true
    }
  }
}
