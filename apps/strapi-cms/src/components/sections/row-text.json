{
  "collectionName": "components_sections_row_texts",
  "info": {
    "displayName": "RowText",
    "description": ""
  },
  "options": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "subtitle": {
      "type": "text"
    },
    "layout": {
      "type": "enumeration",
      "required": true,
      "default": "left",
      "enum": [
        "left",
        "center"
      ]
    },
    "sectionID": {
      "type": "string",
      "regex": "^[a-z]+[a-z\\-]*$"
    },
    "body": {
      "type": "richtext"
    },
    "titleTag": {
      "type": "enumeration",
      "default": "h2",
      "enum": [
        "h1",
        "h2",
        "h3",
        "h4",
        "h5",
        "h6",
        "p"
      ]
    }
  }
}
