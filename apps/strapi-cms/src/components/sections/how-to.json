{
  "collectionName": "components_sections_how_tos",
  "info": {
    "displayName": "HowTo",
    "description": ""
  },
  "options": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "theme": {
      "type": "enumeration",
      "required": true,
      "default": "light",
      "enum": [
        "light",
        "dark"
      ]
    },
    "link": {
      "type": "component",
      "component": "components.link",
      "repeatable": false
    },
    "ctaButton": {
      "type": "component",
      "component": "components.cta-button-simple",
      "repeatable": false
    },
    "rowMaxSteps": {
      "type": "integer",
      "required": true,
      "default": 4,
      "min": 1,
      "max": 6
    },
    "stepsAlignment": {
      "type": "enumeration",
      "required": true,
      "default": "center",
      "enum": [
        "center",
        "left",
        "right"
      ]
    },
    "steps": {
      "type": "component",
      "component": "components.step",
      "repeatable": true,
      "required": true,
      "min": 2
    },
    "sectionID": {
      "type": "string",
      "unique": false,
      "regex": "^[a-z]+[a-z\\-]*$"
    },
    "customBgColor": {
      "type": "customField",
      "customField": "plugin::color-picker.color",
      "regex": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$"
    }
  }
}
