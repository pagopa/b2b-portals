{
  "collectionName": "components_sections_features",
  "info": {
    "displayName": "Feature",
    "description": ""
  },
  "options": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "theme": {
      "type": "enumeration",
      "required": true,
      "default": "light",
      "enum": [
        "light",
        "dark"
      ]
    },
    "showCarouselMobile": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "items": {
      "type": "component",
      "component": "components.feature-item",
      "repeatable": true,
      "required": true,
      "min": 3,
      "max": 4
    },
    "sectionID": {
      "type": "string",
      "unique": false,
      "regex": "^[a-z]+[a-z\\-]*$"
    },
    "customBgColor": {
      "type": "customField",
      "customField": "plugin::color-picker.color",
      "regex": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$"
    }
  }
}
